# Optional: raises GitHub's unauthenticated 60 req/hr rate limit to 5,000 req/hr.
# Create a fine-grained token with no scopes (public data only) at
# https://github.com/settings/tokens
GITHUB_TOKEN=

# Optional: enables the /api/contact route to actually deliver email via Resend.
# https://resend.com
RESEND_API_KEY=
CONTACT_TO_EMAIL=you@example.com
